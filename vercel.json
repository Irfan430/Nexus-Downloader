{
  "version": 2,
  "name": "nexus-downloader",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/dashboard/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/resolve",
      "dest": "/api/index.js"
    },
    {
      "src": "/download",
      "dest": "/api/index.js"
    },
    {
      "src": "/status/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/file/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "QUEUE_BACKEND": "memory",
    "DOWNLOAD_DIR": "/tmp",
    "LOG_DIR": "/tmp",
    "PUBLIC_MODE": "true"
  }
}
